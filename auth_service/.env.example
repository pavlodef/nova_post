# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL
DB_NAME=users_db
DB_PORT=5432
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_db_password

# MongoDB (optional audit log)
MONGO_DB_USER=your_mongo_user
MONGO_DB_PASSWORD=your_mongo_password
MONGO_DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
